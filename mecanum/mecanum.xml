<mujoco>
    <compiler angle="radian" autolimits="true"/>
    <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast" density="1.225" viscosity="1.8e-5"/>
    <visual>
        <global realtime="1"/>
        <quality shadowsize="16384" numslices="28" offsamples="4"/>
        <headlight diffuse="3 3 3" specular=".5 .5 .5" active="1"/>
        <rgba fog="0 1 0 1" haze="1 1 1 1"/>
    </visual>
    <asset>
        <texture name="skybox" type="skybox" builtin="gradient" rgb1=".1 .1 .1" rgb2=".9 .9 .9" width="512" height="512"/>
        <texture name="plane" type="2d" builtin="checker" rgb1=".1 .1 .1" rgb2=".9 .9 .9" width="512" height="512"/>
        <material name="plane" texture="plane" reflectance="0.3"/>
    </asset>

    <worldbody>
        <geom name="floor" type="plane" material="plane" size="0 0 0.25" pos="0 0 0"/>

        <body name="base_body" pos="0 0 0.01">
            <freejoint/>
            <geom type="box" size="0.5 0.5 0.01" rgba=".2 .2 .2 1" mass="15"/> 
            <site name="imu" type="box" size=".05 .05 .02"/>  
            <body name="Mecanum_A1" pos="0.6 0.5 0" euler="0 1.57 0">
                <joint type="hinge" name="a1" axis="0 0 1" pos="0 0 0" frictionloss=".00002"/>
                <geom type="cylinder" size="0.05 0.1" rgba=".2 .2 .2 1"/>
                <geom type="cylinder" size="0.15 0.045" rgba=".5 .1 .1 .5"/>
                <replicate count="16" euler="0 0 0.3925">
                    <body euler="-0.78 0 0">
                    <joint type="hinge" axis="0 0 1" pos="0.15 0 0" frictionloss=".00002"/>
                    <geom type="capsule" size="0.015 0.05" pos="0.15 0 0"/>
                    </body>
                </replicate>   
            </body>   
            
            <body name="Mecanum_A2" pos="-0.6 -0.5 0" euler="0 1.57 0">
                <joint type="hinge" name="a2" axis="0 0 1" pos="0 0 0" frictionloss=".00002"/>
                <geom type="cylinder" size="0.05 0.1" rgba=".2 .2 .2 1"/>
                <geom type="cylinder" size="0.15 0.045" rgba=".5 .1 .1 .5"/>
                <replicate count="16" euler="0 0 0.3925">
                    <body euler="-0.78 0 0">
                    <joint type="hinge" axis="0 0 1" pos="0.15 0 0" frictionloss=".00002"/>
                    <geom type="capsule" size="0.015 0.05" pos="0.15 0 0"/>
                    </body>
                </replicate> 
            </body> 

            <body name="Mecanum_B1" pos="0.6 -0.5 0" euler="0 1.57 0">
                <joint type="hinge" name="b1" axis="0 0 1" pos="0 0 0" frictionloss=".00002"/>
                <geom type="cylinder" size="0.05 0.1" rgba=".2 .2 .2 1"/>
                <geom type="cylinder" size="0.15 0.045" rgba=".5 .1 .1 .5"/>
                <replicate count="16" euler="0 0 0.3925">
                    <body euler="0.78 0 0">
                    <joint type="hinge" axis="0 0 1" pos="0.15 0 0" frictionloss=".00002"/>
                    <geom type="capsule" size="0.015 0.05" pos="0.15 0 0"/>
                    </body>
                </replicate> 
            </body> 

            <body name="Mecanum_B2" pos="-0.6 0.5 0" euler="0 1.57 0">
                <joint type="hinge" name="b2" axis="0 0 1" pos="0 0 0" frictionloss=".00002"/>
                <geom type="cylinder" size="0.05 0.1" rgba=".2 .2 .2 1"/>
                <geom type="cylinder" size="0.15 0.045" rgba=".5 .1 .1 .5"/>
                <replicate count="16" euler="0 0 0.3925">
                    <body euler="0.78 0 0">
                    <joint type="hinge" axis="0 0 1" pos="0.15 0 0" frictionloss=".00002"/>
                    <geom type="capsule" size="0.015 0.05" pos="0.15 0 0"/>
                    </body>
                </replicate> 
            </body> 

        </body>
    </worldbody>

    <tendon>
        <fixed name="forward">
            <joint joint="a1" coef="0.25"/>
            <joint joint="a2" coef="0.25"/>
            <joint joint="b1" coef="0.25"/>
            <joint joint="b2" coef="0.25"/>
        </fixed>
        <fixed name="transverse" frictionloss=".001">
           <joint joint="a1" coef="1"/>
            <joint joint="a2" coef="1"/>
            <joint joint="b1" coef="-1"/>
            <joint joint="b2" coef="-1"/>
        </fixed>
        <fixed name="rotate">
            <joint joint="a1" coef="0.25"/>
            <joint joint="a2" coef="-0.25"/>
            <joint joint="b1" coef="0.25"/>
            <joint joint="b2" coef="-0.25"/>
        </fixed>
    </tendon>

    <actuator>
        <velocity tendon="forward" name="forward" kv="30" ctrlrange="-15 15"/>
        <velocity tendon="transverse" name="transverse" kv="30" ctrlrange="-15 15"/>
        <velocity tendon="rotate" name="rotate" kv="30" ctrlrange="-15 15"/>
        <velocity joint="a1" name="a1" kv="30" ctrlrange="-15 15"/>
        <velocity joint="a2" name="a2" kv="30" ctrlrange="-15 15"/>
        <velocity joint="b1" name="b1" kv="30" ctrlrange="-15 15"/>
        <velocity joint="b2" name="b2" kv="30" ctrlrange="-15 15"/>
    </actuator>

    <sensor>
        <framequat name="orientation" objtype="site" objname="imu"/>
        <accelerometer name="acc" site="imu"/>
        <gyro name="gyro" site="imu"/>
    </sensor>
</mujoco>