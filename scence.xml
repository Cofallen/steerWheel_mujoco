<mujoco>
    <compiler angle="radian" autolimits="true"/>
    <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast" density="1.225" viscosity="1.8e-5"/>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1=".1 .1 .1" rgb2=".9 .9 .9" width="512" height="512"/>
        <texture name="plane" type="2d" builtin="checker" rgb1=".1 .1 .1" rgb2=".9 .9 .9" width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
        <material name="plane" reflectance="0.3" texture="plane" texrepeat="1 1" texuniform="true"/>
    </asset>

    <worldbody>
        <geom type="plane" material="plane" pos="0 0 0" size="0 0 .25"/>
        <light directional="true" dir="0 0 -1" diffuse="1 1 1" specular=".5 .5 .5"/>

        <body name="robot">
        
        <freejoint/>
        <body name="body" pos="0 0 0.15">
            <geom type="cylinder" size="0.25 0.01" pos="0 0 0" rgba="1 1 1 0.6" mass="3.0"/>

            <replicate count="4" euler="0 0 1.57">
                <body name="steerWheel" pos="0.2 0 -0.03">
                    <geom name="steer" type="cylinder" size="0.05 0.02" pos="0 0 0" rgba="1 0 0 0.6" mass="1.0"/>
                    <joint name="steer" type="hinge" axis="0 0 1" pos="0 0 0"/>

                    <body name="wheel" pos="0 0 -0.07">
                        <geom type="cylinder" size="0.05 0.01" pos="0 0 0" euler="1.57 0 0" rgba="0 1 0 0.6" mass="1.0"/>
                        <joint name="wheel" type="hinge" axis="0 1 0"/>
                    </body>

                </body>
            </replicate>

            </body>
        </body>
        
    </worldbody>

    <actuator>
        <position name="steer0" joint="steer0" kp="2" kv="0.1" ctrlrange="-3.14 3.14"/>
        <position name="steer1" joint="steer1" kp="2" kv="0.1" ctrlrange="-3.14 3.14"/>
        <position name="steer2" joint="steer2" kp="2" kv="0.1" ctrlrange="-3.14 3.14"/>
        <position name="steer3" joint="steer3" kp="2" kv="0.1" ctrlrange="-3.14 3.14"/>
        <velocity name="wheel0" joint="wheel0" kv="1" ctrlrange="-5 5"/>
        <velocity name="wheel1" joint="wheel1" kv="1" ctrlrange="-5 5"/>
        <velocity name="wheel2" joint="wheel2" kv="1" ctrlrange="-5 5"/>
        <velocity name="wheel3" joint="wheel3" kv="1" ctrlrange="-5 5"/>
    </actuator>
    
</mujoco>